#!/usr/bin/env python3
"""Zylch AI CLI launcher script.

Usage:
    ./zylch-cli                    # Start CLI (requires login)
    ./zylch-cli --login            # Login via browser
    ./zylch-cli --logout           # Logout and clear credentials
    ./zylch-cli --status           # Check login status
    ./zylch-cli --log-level info   # Start with INFO logging
    ./zylch-cli -l info            # Short form
"""

import argparse
import logging
import sys
import os

# Add the project root to path if running from project directory
script_dir = os.path.dirname(os.path.abspath(__file__))
if script_dir not in sys.path:
    sys.path.insert(0, script_dir)


def setup_logging(log_level: str) -> None:
    """Configure logging based on user preference.

    Args:
        log_level: One of '0', 'quiet', 'info', 'warning', 'error'
    """
    level_map = {
        '0': logging.ERROR,       # Quiet - only errors
        'quiet': logging.ERROR,   # Same as 0
        'info': logging.INFO,
        'warning': logging.WARNING,
        'error': logging.ERROR,
    }

    level = level_map.get(log_level.lower(), logging.ERROR)

    # Configure root logger
    logging.basicConfig(
        level=level,
        format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
        force=True  # Override any existing config
    )

    # Set level for all zylch loggers
    for name in logging.Logger.manager.loggerDict:
        if name.startswith('zylch'):
            logging.getLogger(name).setLevel(level)

    # Also set for common noisy libraries
    for lib_name in ['httpx', 'httpcore', 'anthropic', 'hpack']:
        logging.getLogger(lib_name).setLevel(max(level, logging.WARNING))


def handle_auth_command(command: str) -> int:
    """Handle authentication commands.

    Args:
        command: One of 'login', 'logout', 'status'

    Returns:
        Exit code (0 = success)
    """
    from zylch.cli.auth import CLIAuthManager

    auth = CLIAuthManager()

    if command == 'login':
        success = auth.login()
        return 0 if success else 1

    elif command == 'logout':
        success = auth.logout()
        return 0 if success else 1

    elif command == 'status':
        if auth.is_authenticated():
            info = auth.get_user_info()
            print(f"Logged in as {info.get('display_name', 'User')} ({info.get('email', 'unknown')})")
            print(f"   Owner ID: {info.get('owner_id', 'unknown')}")
            return 0
        else:
            print("Not logged in")
            print("   Run: zylch-cli --login")
            return 1

    return 1


def main():
    parser = argparse.ArgumentParser(
        description='Zylch AI - Email Intelligence Assistant',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Authentication:
  --login    Login via browser (Firebase)
  --logout   Logout and clear stored credentials
  --status   Check current login status

Log levels:
  0, quiet   Only show errors (default)
  info       Show INFO messages and above
  warning    Show WARNING messages and above
  error      Show only ERROR messages

Examples:
  ./zylch-cli --login              Login via browser
  ./zylch-cli                      Start CLI (requires login)
  ./zylch-cli -l info              Start with INFO logging
"""
    )

    # Auth commands (mutually exclusive)
    auth_group = parser.add_mutually_exclusive_group()
    auth_group.add_argument(
        '--login',
        action='store_true',
        help='Login via browser (Firebase)'
    )
    auth_group.add_argument(
        '--logout',
        action='store_true',
        help='Logout and clear credentials'
    )
    auth_group.add_argument(
        '--status',
        action='store_true',
        help='Check login status'
    )

    parser.add_argument(
        '-l', '--log-level',
        type=str,
        default='0',
        choices=['0', 'quiet', 'info', 'warning', 'error'],
        help='Logging level (default: 0/quiet)'
    )

    args = parser.parse_args()

    # Setup logging before importing zylch modules
    setup_logging(args.log_level)

    # Handle auth commands first
    if args.login:
        result = handle_auth_command('login')
        if result != 0:
            sys.exit(result)  # Exit only on failure
        # On success, continue to start CLI
        print()  # Blank line before CLI startup

    elif args.logout:
        sys.exit(handle_auth_command('logout'))
    elif args.status:
        sys.exit(handle_auth_command('status'))

    # Normal CLI startup - import and run
    from zylch.cli.main import main as cli_main
    cli_main()


if __name__ == '__main__':
    main()
