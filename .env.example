# =============================================================================
# Zylch AI Environment Configuration Template
# =============================================================================
# Copy this file to `.env` and fill in your actual values.
#
# BYOK Model:
# User credentials (LLM API keys, Pipedrive, SendGrid, Vonage) are NOT in .env.
# Users connect their services via /connect commands - stored in Supabase.
# =============================================================================

# =============================================================================
# 1. LOGGING
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# 2. LLM MODEL SETTINGS
# =============================================================================
# Model configuration (users connect their API key via /connect <provider>)
DEFAULT_MODEL=claude-sonnet-4-20250514
CLASSIFICATION_MODEL=claude-3-5-haiku-20241022
EXECUTIVE_MODEL=claude-opus-4-20250514

# Skill System Models
SKILL_ROUTER_MODEL=claude-3-5-haiku-20241022
SKILL_EXECUTION_MODEL=claude-sonnet-4-20250514
SKILL_PATTERN_MODEL=claude-3-5-haiku-20241022

# =============================================================================
# 3. PERFORMANCE
# =============================================================================
ENABLE_PROMPT_CACHING=true

# =============================================================================
# 4. GOOGLE OAUTH (System-Level)
# =============================================================================
# System-level OAuth credentials from Google Cloud Console
# User tokens are stored in Supabase per-user
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
CALENDAR_ID=primary

# =============================================================================
# 5. FIREBASE AUTHENTICATION
# =============================================================================
# Firebase service account (base64-encoded JSON)
# Generate: cat firebase-service-account.json | base64
FIREBASE_SERVICE_ACCOUNT_BASE64=base64-encoded-service-account-json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=AIzaSy...your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# =============================================================================
# 6. SUPABASE (Multi-Tenant Database)
# =============================================================================
# All data stored in Supabase per ARCHITECTURE.md
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# 7. ENCRYPTION
# =============================================================================
# Fernet encryption key for sensitive data at rest
# Generate: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
ENCRYPTION_KEY=your-encryption-key

# =============================================================================
# 8. CORS SETTINGS
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# =============================================================================
# 9. WEBHOOK SERVER
# =============================================================================
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_PUBLIC_URL=http://localhost:8000

# =============================================================================
# 10. MRCALL OAUTH (via StarChat API)
# =============================================================================
MRCALL_CLIENT_ID=your-mrcall-client-id
MRCALL_CLIENT_SECRET=your-mrcall-client-secret
MRCALL_REALM=mrcall0
MRCALL_BASE_URL=https://api.mrcall.ai
MRCALL_OAUTH_AUTHORIZE_URL=https://dashboard.mrcall.ai/oauth/authorize
