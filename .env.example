# =============================================================================
# Zylch AI Environment Configuration Template
# =============================================================================
# This is a template for environment variables used by Zylch AI.
# Copy this file to `.env` and fill in your actual values.
#
# For Railway deployment:
# - Add these variables in the Railway dashboard under your service settings
# - DO NOT commit actual values to version control
# - Use Railway's secrets management for sensitive data
# =============================================================================

# =============================================================================
# 1. MODEL SETTINGS
# =============================================================================
# Model configuration (optional - defaults provided)
# NOTE: Anthropic API keys are per-user via /connect anthropic (BYOK, stored in Supabase)
DEFAULT_MODEL=claude-sonnet-4-20250514
CLASSIFICATION_MODEL=claude-3-5-haiku-20241022
EXECUTIVE_MODEL=claude-opus-4-20250514

# =============================================================================
# 2. GOOGLE OAUTH (System-Level)
# =============================================================================
# System-level OAuth credentials from Google Cloud Console
# Used for server-side OAuth flows - user tokens stored in Supabase
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
CALENDAR_ID=primary

# =============================================================================
# 3. FIREBASE AUTHENTICATION
# =============================================================================
# Firebase service account (base64-encoded JSON)
# Create: cat firebase-service-account.json | base64
FIREBASE_SERVICE_ACCOUNT_BASE64=base64-encoded-service-account-json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=AIzaSy...your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# =============================================================================
# 4. SUPABASE (Multi-Tenant Database)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# 5. ENCRYPTION
# =============================================================================
# Fernet encryption key for sensitive data at rest
# Generate: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
ENCRYPTION_KEY=your-encryption-key

# =============================================================================
# 6. SENDGRID EMAIL SERVICE
# =============================================================================
# SendGrid API key (per-user via /connect sendgrid recommended)
SENDGRID_API_KEY=your_sendgrid_api_key

# =============================================================================
# 7. WEBHOOK SERVER
# =============================================================================
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_PUBLIC_URL=http://localhost

# =============================================================================
# 8. CORS SETTINGS
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# =============================================================================
# 9. EMAIL CONFIGURATION
# =============================================================================
MADE_BY_ZYLCH_EMAIL=Written with the help of Zylch AI
EMAIL_STYLE_PROMPT=Write concisely and professionally. No emojis.
BOT_EMAILS=*@noreply.*,*@no-reply.*,noreply@*,no-reply@*,*@notifications.*,notifications@*,*@updates.*,updates@*,*@alerts.*,alerts@*,*@automated.*,automated@*

# =============================================================================
# 10. CACHE & DATA STORAGE
# =============================================================================
CACHE_DIR=cache/
CACHE_TTL_DAYS=30
CAMPAIGNS_FILE=data/campaigns.json
TEMPLATES_FILE=data/templates.json

# =============================================================================
# 11. EMAIL ARCHIVE
# =============================================================================
EMAIL_ARCHIVE_BACKEND=sqlite
EMAIL_ARCHIVE_SQLITE_PATH=cache/emails/archive.db
EMAIL_ARCHIVE_INITIAL_MONTHS=1
EMAIL_ARCHIVE_BATCH_SIZE=500
EMAIL_ARCHIVE_ENABLE_FTS=true

# =============================================================================
# 12. INTEGRATIONS
# =============================================================================
# Pipedrive: API token is per-user via /connect pipedrive (BYOK)
PIPEDRIVE_ENABLED=false

# =============================================================================
# 13. SKILL SYSTEM
# =============================================================================
SKILL_ROUTER_MODEL=claude-3-5-haiku-20241022
SKILL_EXECUTION_MODEL=claude-sonnet-4-20250514
SKILL_PATTERN_MODEL=claude-3-5-haiku-20241022

# =============================================================================
# 14. PERFORMANCE & OPTIMIZATION
# =============================================================================
ENABLE_PROMPT_CACHING=true
ENABLE_BATCH_PROCESSING=false

# =============================================================================
# 15. PATTERN LEARNING
# =============================================================================
PATTERN_STORE_ENABLED=true
PATTERN_CONFIDENCE_THRESHOLD=0.5
PATTERN_MAX_RESULTS=3

# =============================================================================
# 16. STORAGE BACKEND
# =============================================================================
STORAGE_BACKEND=json
