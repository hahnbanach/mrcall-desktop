# =============================================================================
# Zylch AI Environment Configuration Template
# =============================================================================
# Copy this file to `.env` and fill in your actual values.
#
# For Railway deployment, add these variables in the Railway dashboard.
# DO NOT commit actual values to version control.
#
# Per-user credentials (LLM API keys, Pipedrive, SendGrid, Vonage) are stored
# in Supabase via /connect commands (BYOK model) - NOT in this file.
# =============================================================================

# =============================================================================
# 1. LOGGING
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# 2. GOOGLE OAUTH (System-Level)
# =============================================================================
# System-level OAuth credentials from Google Cloud Console
# Used for server-side OAuth flows - user tokens stored in Supabase
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# =============================================================================
# 3. FIREBASE AUTHENTICATION
# =============================================================================
# Firebase service account (base64-encoded JSON)
# Create: cat firebase-service-account.json | base64
FIREBASE_SERVICE_ACCOUNT_BASE64=base64-encoded-service-account-json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=AIzaSy...your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# =============================================================================
# 4. SUPABASE (Multi-Tenant Database)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# 5. ENCRYPTION
# =============================================================================
# Fernet encryption key for sensitive data at rest
# Generate: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
ENCRYPTION_KEY=your-encryption-key

# =============================================================================
# 6. CORS SETTINGS
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# =============================================================================
# 7. WEBHOOK SERVER
# =============================================================================
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_PUBLIC_URL=https://api.your-domain.com

# =============================================================================
# 8. MRCALL OAUTH (System-Level)
# =============================================================================
# OAuth client credentials for MrCall/StarChat integration
MRCALL_CLIENT_ID=partner_your_client_id
MRCALL_CLIENT_SECRET=your-client-secret
MRCALL_REALM=mrcall0
MRCALL_BASE_URL=https://api.mrcall.ai
MRCALL_OAUTH_AUTHORIZE_URL=https://dashboard.mrcall.ai/oauth/authorize

# =============================================================================
# 9. PERFORMANCE
# =============================================================================
ENABLE_PROMPT_CACHING=true

# =============================================================================
# 10. LLM MODELS (one per provider)
# =============================================================================
# Override the default model for each provider
# ANTHROPIC_MODEL=claude-opus-4-6-20260205
# OPENAI_MODEL=gpt-4.1
# MISTRAL_MODEL=mistral-large-3
# DEFAULT_MODEL=claude-opus-4-6-20260205
