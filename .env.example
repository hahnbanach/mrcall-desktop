# =============================================================================
# Zylch AI Environment Configuration Template
# =============================================================================
# This is a template for environment variables used by Zylch AI.
# Copy this file to `.env` and fill in your actual values.
#
# For Railway deployment:
# - Add these variables in the Railway dashboard under your service settings
# - DO NOT commit actual values to version control
# - Use Railway's secrets management for sensitive data
# =============================================================================

# =============================================================================
# 1. ANTHROPIC API SETTINGS
# =============================================================================
# Required: Your Anthropic API key for Claude AI models
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model configuration (optional - defaults provided)
DEFAULT_MODEL=claude-sonnet-4-20250514
CLASSIFICATION_MODEL=claude-3-5-haiku-20241022
EXECUTIVE_MODEL=claude-opus-4-20250514

# =============================================================================
# 2. GOOGLE OAUTH CREDENTIALS
# =============================================================================
# Path to Google OAuth credentials JSON file (for Gmail, Calendar, etc.)
GOOGLE_CREDENTIALS_PATH=credentials/google_oauth.json

# Directory for storing Google OAuth tokens (isolated per-user)
GOOGLE_TOKEN_PATH=~/.zylch/credentials/google

# Comma-separated list of authorized Gmail accounts
GMAIL_ACCOUNTS=[]  # JSON array of authorized accounts

# Google Calendar ID (default: "primary")
CALENDAR_ID=primary

# =============================================================================
# 3. FIREBASE AUTHENTICATION
# =============================================================================
# Firebase Server SDK (for backend authentication)
FIREBASE_SERVICE_ACCOUNT_PATH=credentials/firebase_service_account.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase Client SDK (for CLI browser-based login)
FIREBASE_API_KEY=AIzaSy...your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# =============================================================================
# 4. MICROSOFT GRAPH API (Outlook Integration)
# =============================================================================
# Microsoft Graph API tokens (obtained from login flow)
GRAPH_TOKEN=
GRAPH_REFRESH_TOKEN=

# Authentication provider (google.com or microsoft.com)
AUTH_PROVIDER=google.com

# =============================================================================
# 5. STARCHAT/MRCALL INTEGRATION
# =============================================================================
# StarChat API configuration
STARCHAT_API_URL=https://mrcall-0.scw.hbsrv.net:443
STARCHAT_API_KEY=
STARCHAT_USERNAME=admin
STARCHAT_PASSWORD=
STARCHAT_BUSINESS_ID=
STARCHAT_AUTH_METHOD=basic
STARCHAT_WEBHOOK_SECRET=

# =============================================================================
# 6. SENDGRID EMAIL SERVICE
# =============================================================================
# SendGrid API configuration
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_WEBHOOK_SECRET=

# =============================================================================
# 7. VONAGE SMS SERVICE
# =============================================================================
# Vonage API credentials
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=

# =============================================================================
# 8. WEBHOOK SERVER CONFIGURATION
# =============================================================================
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_PUBLIC_URL=http://localhost

# =============================================================================
# 9. API SERVER (Thin Client)
# =============================================================================
# API Server URL for CLI thin client
API_SERVER_URL=http://localhost:9000

# =============================================================================
# 10. CORS SETTINGS
# =============================================================================
# Comma-separated list of allowed CORS origins for dashboard integration
# Development: http://localhost:8080,http://localhost:3000
# Production: https://dashboard.mrcall.ai,https://mrcall.ai
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# =============================================================================
# 11. MULTI-TENANT CONFIGURATION
# =============================================================================
# Owner and assistant identifiers
# OWNER_ID: Firebase UID or placeholder (e.g., "owner_mario")
# ZYLCH_ASSISTANT_ID: Zylch assistant identifier (e.g., "default_assistant")
OWNER_ID=owner_default
ZYLCH_ASSISTANT_ID=default_assistant

# User identity for sharing features
USER_EMAIL=
USER_DISPLAY_NAME=

# =============================================================================
# 12. EMAIL STYLE CONFIGURATION
# =============================================================================
# Email signature appended to outgoing emails
MADE_BY_ZYLCH_EMAIL=Written with the help of Zylch AI

# Custom email writing style instructions
EMAIL_STYLE_PROMPT=Write concisely and professionally. No emojis.

# Comma-separated list of your email addresses (supports wildcards like *@domain.com)
MY_EMAILS=you@example.com,*@yourdomain.com

# Comma-separated bot email patterns to downgrade priority (supports wildcards)
BOT_EMAILS=*@noreply.*,*@no-reply.*,noreply@*,no-reply@*,*@notifications.*,notifications@*,*@updates.*,updates@*,*@alerts.*,alerts@*,*@automated.*,automated@*

# =============================================================================
# 13. CACHE & DATA STORAGE
# =============================================================================
# Cache directory and TTL settings
CACHE_DIR=cache/
CACHE_TTL_DAYS=30

# Campaign and template data files
CAMPAIGNS_FILE=data/campaigns.json
TEMPLATES_FILE=data/templates.json

# =============================================================================
# 14. EMAIL ARCHIVE CONFIGURATION
# =============================================================================
# Email archive backend: sqlite or postgres
EMAIL_ARCHIVE_BACKEND=sqlite
EMAIL_ARCHIVE_SQLITE_PATH=cache/emails/archive.db

# PostgreSQL connection URL (if using postgres backend)
EMAIL_ARCHIVE_POSTGRES_URL=

# Email archive sync settings
EMAIL_ARCHIVE_INITIAL_MONTHS=1
EMAIL_ARCHIVE_BATCH_SIZE=500
EMAIL_ARCHIVE_ENABLE_FTS=true

# =============================================================================
# 15. PIPEDRIVE CRM (Optional)
# =============================================================================
# Pipedrive integration (set PIPEDRIVE_ENABLED=true to activate)
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_ENABLED=false

# =============================================================================
# 16. APOLLO.IO (Future Integration)
# =============================================================================
# Apollo.io API (set APOLLO_ENABLED=true to activate)
APOLLO_API_KEY=
APOLLO_ENABLED=false

# =============================================================================
# 17. SKILL SYSTEM CONFIGURATION
# =============================================================================
# Model Selection for Different Skill Operations
SKILL_ROUTER_MODEL=claude-3-5-haiku-20241022
SKILL_EXECUTION_MODEL=claude-sonnet-4-20250514
SKILL_PATTERN_MODEL=claude-3-5-haiku-20241022

# =============================================================================
# 18. PERFORMANCE OPTIMIZATION
# =============================================================================
# Performance features
ENABLE_PROMPT_CACHING=true
ENABLE_BATCH_PROCESSING=false
CLAUDE_QUEUE_ENABLED=false

# =============================================================================
# 19. PATTERN LEARNING SYSTEM
# =============================================================================
# Pattern learning configuration
PATTERN_STORE_ENABLED=true
PATTERN_STORE_PATH=.swarm/patterns.db
PATTERN_CONFIDENCE_THRESHOLD=0.5
PATTERN_MAX_RESULTS=3

# =============================================================================
# 20. STORAGE BACKEND CONFIGURATION
# =============================================================================
# Storage backend: json, sqlite, or hybrid
STORAGE_BACKEND=json
SQLITE_DB_PATH=.swarm/threads.db

# =============================================================================
# 21. FEATURE FLAGS
# =============================================================================
# Enable skill-based interface
SKILL_MODE_ENABLED=false
