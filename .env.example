# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEFAULT_MODEL=claude-sonnet-4-20250514
CLASSIFICATION_MODEL=claude-3-5-haiku-20241022
EXECUTIVE_MODEL=claude-opus-4-20250514

# Gmail API
GMAIL_CREDENTIALS_PATH=credentials/gmail_oauth.json
GMAIL_TOKEN_PATH=credentials/gmail_tokens/
GMAIL_ACCOUNTS=[]  # JSON array of authorized accounts

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_WEBHOOK_SECRET=

# Vonage SMS
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=

# Webhook Server
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_PUBLIC_URL=http://localhost

# Google Calendar
CALENDAR_CREDENTIALS_PATH=credentials/calendar_oauth.json
CALENDAR_ID=primary

# Firebase Authentication (for dashboard integration)
FIREBASE_SERVICE_ACCOUNT_PATH=credentials/firebase_service_account.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# CORS Configuration (for dashboard integration)
# Development: http://localhost:8080,http://localhost:3000
# Production: https://dashboard.mrcall.ai,https://mrcall.ai
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# StarChat API
STARCHAT_API_URL=https://mrcall-0.scw.hbsrv.net:443
STARCHAT_USERNAME=admin
STARCHAT_PASSWORD=
STARCHAT_BUSINESS_ID=
STARCHAT_AUTH_METHOD=basic

# Multi-tenant Configuration
# OWNER_ID: Firebase UID or placeholder (e.g., "owner_mario")
# ZYLCH_ASSISTANT_ID: Zylch assistant identifier (e.g., "default_assistant")
OWNER_ID=owner_default
ZYLCH_ASSISTANT_ID=default_assistant

# Cache
CACHE_DIR=cache/
CACHE_TTL_DAYS=30

# Email Archive Configuration
EMAIL_ARCHIVE_BACKEND=sqlite
EMAIL_ARCHIVE_SQLITE_PATH=cache/emails/archive.db
EMAIL_ARCHIVE_POSTGRES_URL=
EMAIL_ARCHIVE_INITIAL_MONTHS=1
EMAIL_ARCHIVE_BATCH_SIZE=500
EMAIL_ARCHIVE_ENABLE_FTS=true

# Campaign Data
CAMPAIGNS_FILE=data/campaigns.json
TEMPLATES_FILE=data/templates.json

# CRM (Optional)
PIPEDRIVE_API_TOKEN=***REMOVED***
PIPEDRIVE_ENABLED=true

# Apollo (Future)
APOLLO_API_KEY=
APOLLO_ENABLED=false

# Email Intelligence
MY_EMAILS=mario.alemi@mrcall.ai,support@mrcall.ai
EMAIL_STYLE_PROMPT=Write concisely and professionally. No emojis.
MADE_BY_ZYLCH_EMAIL=Written with the help of Zylch AI

# Bot Detection (automated emails to downgrade priority)
BOT_EMAILS=*@noreply.*,*@no-reply.*,noreply@*,no-reply@*,*@notifications.*,notifications@*,*@updates.*,updates@*,*@alerts.*,alerts@*,*@automated.*,automated@*

# Skill System Configuration
# Model Selection for Different Skill Operations
SKILL_ROUTER_MODEL=claude-3-5-haiku-20241022  # Intent classification (fast, cheap)
SKILL_EXECUTION_MODEL=claude-sonnet-4-20250514  # Skill execution (accurate)
SKILL_PATTERN_MODEL=claude-3-5-haiku-20241022  # Pattern matching (fast)

# Performance Optimization
ENABLE_PROMPT_CACHING=true
ENABLE_BATCH_PROCESSING=false  # Requires Anthropic Batches API access
CLAUDE_QUEUE_ENABLED=false  # Enable API request queue

# Pattern Learning System
PATTERN_STORE_ENABLED=true
PATTERN_STORE_PATH=.swarm/patterns.db  # SQLite database for patterns
PATTERN_CONFIDENCE_THRESHOLD=0.5
PATTERN_MAX_RESULTS=3

# Storage Backend Options
STORAGE_BACKEND=json  # Options: json, sqlite, hybrid
SQLITE_DB_PATH=.swarm/threads.db

# Skill System Feature Flags
SKILL_MODE_ENABLED=false  # Enable natural language skill-based interface
